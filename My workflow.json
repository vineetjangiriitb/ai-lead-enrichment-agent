    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst profile = $('Edit Fields').first().json;\nconst enrichment = $('Code in JavaScript').first().json;\n\nconst raw = input.candidates[0].content.parts[0].text;\nconst cleaned = raw.replace(/```json|```/g, \"\").trim();\nconst parsed = JSON.parse(cleaned);\n\nreturn [{\n  json: {\n    linkedin_url: profile.linkedin_url,\n    full_name: profile.full_name,\n    headline: profile.headline,\n    fit_score: enrichment.fit_score,\n    pain_points: enrichment.pain_points,\n    subject: parsed.subject,\n    email_draft: parsed.body,\n    status: \"done\"\n  }\n}];"
      },
