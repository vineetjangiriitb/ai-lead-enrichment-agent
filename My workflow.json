        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"You are a senior SDR writing a cold outreach email. Return ONLY valid JSON with no markdown, no backticks.\\n\\nProspect details:\\nName: {{$json.full_name}}\\nHeadline: {{$json.headline}}\\nPain points: {{$json.pain_points}}\\nWhy they fit: {{$json.icp_match_reason}}\\n\\nRules:\\n- Subject: one specific hook referencing their role or company\\n- Body: exactly 3 lines. Line 1: one sharp observation about their work. Line 2: one concrete value prop tied to their pain points. Line 3: a soft low-friction CTA.\\n- No 'I hope this finds you well'. No fluff. No buzzwords.\\n\\nReturn exactly this JSON:\\n{\\\"subject\\\": \\\"...\\\", \\\"body\\\": \\\"...\\\"}\"\n        }\n      ]\n    }\n  ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
