    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=AIzaSyA8bh-qiRG30syp1D-_VymebBc4tbCdztc",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"You are a B2B sales intelligence assistant. Given this LinkedIn profile, return ONLY valid JSON with no markdown, no backticks, no explanation.\\n\\nProfile:\\nName: {{$json.full_name}}\\nHeadline: {{$json.headline}}\\nSummary: {{$json.summary}}\\nExperience: {{$json.top_experience}}\\nSkills: {{$json.skills_str}}\\n\\nReturn exactly this JSON structure:\\n{\\\"fit_score\\\": \\\"high\\\" or \\\"med\\\" or \\\"low\\\", \\\"pain_points\\\": [\\\"signal 1\\\", \\\"signal 2\\\"], \\\"icp_match_reason\\\": \\\"one sentence\\\", \\\"skip\\\": false}\\n\\nScore high if: senior IC or decision-maker, SaaS or tech company, mentions automation or AI tools. Score low if: student, non-tech, or profile too sparse. Set skip true only if low.\"\n        }\n      ]\n    }\n  ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        416,
        0
      ],
      "id": "394c1b80-ee74-45d4-a039-64b046273a39",
      "name": "HTTP Request",
      "alwaysOutputData": false
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst profile = $('Edit Fields').first().json;\n\nconst raw = input.candidates[0].content.parts[0].text;\nconst cleaned = raw.replace(/```json|```/g, \"\").trim();\nconst parsed = JSON.parse(cleaned);\n\nconst pain_points = Array.isArray(parsed.pain_points) \n  ? parsed.pain_points.join(\", \") \n  : parsed.pain_points;\n\nreturn [{\n  json: {\n    linkedin_url: profile.linkedin_url,\n    full_name: profile.full_name,\n    headline: profile.headline,\n    summary: profile.summary,\n    fit_score: parsed.fit_score,\n    pain_points: pain_points,\n    icp_match_reason: parsed.icp_match_reason,\n    skip: parsed.skip\n  }\n}];"
      },
